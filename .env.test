# Environnement de test — Supabase LOCAL (Docker)
# Ces valeurs sont les valeurs par défaut de `supabase start`
# Ne contient aucun secret réel, peut être commité.

PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqHDan_WdAgTkRmEPYkMEVsWkEiTxbvuI
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Clés Google OAuth factices (ne permettent pas le vrai flux OAuth, mais affichent le bouton)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=fake-google-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=fake-google-secret

# Mot de passe commun des users de test
TEST_USER_PASSWORD=test-password-123
TEST_ALICE_EMAIL=alice@test.local
TEST_BOB_EMAIL=bob@test.local
TEST_CAROL_EMAIL=carol@test.local
TEST_DAVE_EMAIL=dave@test.local
TEST_GROUP_ID=11111111-1111-1111-1111-111111111111

# PostHog — clé factice, aucun envoi réel en test (réseau intercepté + sink DB)
PUBLIC_POSTHOG_KEY=phc_test_dummy
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
ANALYTICS_TEST_SINK=db
